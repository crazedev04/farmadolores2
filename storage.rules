rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    match /users/{uid}/profile/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    match /farmacias/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /emergencias/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /locales/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promos/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /featured/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
